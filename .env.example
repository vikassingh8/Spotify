# ============================================================
# Spoty — environment configuration (copy to .env)
# ============================================================

# --- Security ---
JWT_SECRET=change-me-in-prod-super-secret-key
JWT_EXPIRES_IN=3600s
# Salt used to anonymize/pseudonymize user IDs before analytics (GDPR/CCPA)
ANONYMIZATION_SALT=spoty-pseudonym-salt-change-me

# --- PostgreSQL ---
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=spoty
POSTGRES_USER=spoty
POSTGRES_PASSWORD=spoty_pw

# --- Redis ---
REDIS_HOST=redis
REDIS_PORT=6379

# --- Kafka ---
KAFKA_BROKERS=kafka:9092
KAFKA_EVENTS_TOPIC=play-events
KAFKA_CLIENT_ID=spoty

# --- MinIO (S3-compatible, maps to Azure Blob in prod) ---
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_ROOT_USER=spotyadmin
MINIO_ROOT_PASSWORD=spotyadmin_pw
MINIO_BUCKET=audio
# Public endpoint used to sign URLs the browser can reach
MINIO_PUBLIC_ENDPOINT=http://localhost:9000

# --- Service ports (host) ---
GATEWAY_HTTP_PORT=8080
GATEWAY_HTTPS_PORT=8443
AUTH_PORT=4001
CATALOG_PORT=4002
PLAYBACK_PORT=4003
RECOMMENDATION_PORT=4004
INGESTION_PORT=4005

# --- Ingestion load simulator ---
SIM_USERS=200
SIM_EVENTS_PER_SEC=50
SIM_AUTOSTART=false
